                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_through_restricted_objects</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>constAccount</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.AccountId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
