    <formulas>
        <name>fFollowUpDate</name>
        <dataType>Date</dataType>
        <expression>BLANKVALUE({!$Record.ActivityDate}, TODAY()) + {!Loop_through_Rules.Days_Till_Follow_Up__c}</expression>
    </formulas>
    <formulas>
        <name>fLowerCaseKeyword</name>
        <dataType>String</dataType>
        <expression>LOWER({!Loop_keywords})</expression>
    </formulas>
    <formulas>
        <name>fLowerCaseSubject</name>
        <dataType>String</dataType>
        <expression>LOWER({!$Record.Subject})</expression>
    </formulas>
    <formulas>
        <description>Returns the task owner&apos;s manager ID if one is assigned, otherwise returns the task owner themself.</description>
        <name>fManagerId</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE({!Get_Task_Owner.ManagerId}, {!$Record.OwnerId})</expression>
    </formulas>
    <formulas>
        <name>fWeekendAdjustedDate</name>
        <dataType>Date</dataType>
        <expression>IF({!Loop_through_Rules.Skip_Weekends__c},
  IF(WEEKDAY({!fFollowUpDate}) = 1, 
    {!fFollowUpDate} + 1,
    IF(WEEKDAY({!fFollowUpDate}) = 6, 
      {!fFollowUpDate} + 2,
      {!fFollowUpDate})),
  {!fFollowUpDate}
)</expression>
    </formulas>
