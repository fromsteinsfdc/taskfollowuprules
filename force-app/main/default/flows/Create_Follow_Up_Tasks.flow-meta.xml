    <decisions>
        <name>Does_Task_match_object</name>
        <label>Does Task match object?</label>
        <locationX>738</locationX>
        <locationY>911</locationY>
        <defaultConnector>
            <targetReference>Loop_through_restricted_objects</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No, Task doesn&apos;t match object</defaultConnectorLabel>
        <rules>
            <name>Yes_Task_matches_object</name>
            <conditionLogic>1 OR 2 OR (3 AND 4)</conditionLogic>
            <conditions>
